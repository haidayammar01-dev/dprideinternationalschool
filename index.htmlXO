}
async function loadVaCalendar(){
  var el=document.getElementById('va-calendar-list');
  try{
    var rows=await sbGet('school_calendar?order=date.asc');
    el.innerHTML=renderDecorativeCalendar(rows,'Dpride International School','School Calendar \u2014 All Events');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load calendar.</div>';}
}
function showVaTab(name,btn){
  document.querySelectorAll('.va-pane').forEach(function(p){p.style.display='none';});
  document.getElementById('va-'+name).style.display='block';
  btn.parentElement.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
}
async function loadVaRoster(){
  var filter=document.getElementById('va-roster-filter').value.trim();
  var el=document.getElementById('va-roster-table');
  el.innerHTML='<div class="loading-txt">Loading\u2026</div>';
  try{
    var q='students?select=*,families(code,parent_name,phone)&order=class_arm.asc,name.asc';
    if(filter)q+='&class_arm=ilike.*'+encodeURIComponent(filter)+'*';
    var rows=await sbGet(q);
    renderRosterTable(rows,'va-roster-table');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load roster.</div>';}
}
async function addAssistant(){
  var code=document.getElementById('va-code').value.trim(),name=document.getElementById('va-name').value.trim();
  if(!code||!name){alert('Code and name are required.');return;}
  try{
    await sbPost('assistants',{code:code,name:name});
    alert('Virtual Assistant added. They can log in with code: '+code);
    document.getElementById('va-code').value='';document.getElementById('va-name').value='';
    loadManageAssistants();
  }catch(e){alert('Could not add (code may already exist): '+e.message);}
}

// ============================================================
// ADMISSIONS (public inquiry form + admin management)
// ============================================================
async function loadAdmissions(){
  var el=document.getElementById('admissions-list');
  try{
    var rows=await sbGet('admissions?order=created_at.desc&limit=100');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No admission inquiries yet.</div>';return;}
    el.innerHTML=rows.map(function(r){
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(r.applicant_name)+' <span style="font-weight:400;color:var(--muted);">('+esc(r.level_applying||'')+')</span></div><div class="lb-sub">Parent: '+esc(r.parent_name||'')+' \u00b7 '+esc(r.phone||'')+(r.email?' \u00b7 '+esc(r.email):'')+(r.notes?' \u00b7 '+esc(r.notes):'')+'</div></div>'
        +'<select onchange="updateAdmissionStatus(\''+r.id+'\',this.value)" style="padding:5px 8px;border-radius:8px;border:1.5px solid var(--border);font-size:12px;">'
        +['new','contacted','admitted','declined'].map(function(s){return '<option value="'+s+'"'+(s===r.status?' selected':'')+'>'+s.charAt(0).toUpperCase()+s.slice(1)+'</option>';}).join('')
        +'</select><button class="btn sm" style="margin-left:8px;background:var(--red-bg);color:var(--red);" onclick="deleteAdmission(\''+r.id+'\')">Delete</button></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load admissions.</div>';}
}
async function loadAddonRequests(){
  var el=document.getElementById('addon-requests-list');
  try{
    var rows=await sbGet('addon_requests?order=created_at.desc&limit=100');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No add-on requests yet.</div>';return;}
    var names={feeding:'School Feeding',one2one:'One on One',arabic:'Arabic Classes',islamiyah:'Islamiyah After-School'};
    el.innerHTML=rows.map(function(r){
      var list=(r.addons||[]).map(function(k){return names[k]||k;}).join(', ');
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(r.family_code)+(r.child_name?' \u2014 '+esc(r.child_name):'')+(r.status==='pending'?' <span class="flag-badge">new</span>':'')+'</div><div class="lb-sub">'+esc(list)+' \u00b7 '+fmtN(r.addons_total||0)+' \u00b7 '+new Date(r.created_at).toLocaleDateString('en-GB')+'</div></div>'
        +(r.status==='pending'?'<button class="btn sm gold" onclick="ackAddonRequest(\''+r.id+'\')">Acknowledge</button>':'')
        +'<button class="btn sm" style="margin-left:8px;background:var(--red-bg);color:var(--red);" onclick="deleteAddonRequest(\''+r.id+'\')">Delete</button></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load requests.</div>';}
}
async function ackAddonRequest(id){
  try{await sbPatch('addon_requests','id=eq.'+id,{status:'acknowledged'});loadAddonRequests();}catch(e){alert('Could not update: '+e.message);}
}
async function deleteAddonRequest(id){
  if(!confirm('Delete this add-on request?'))return;
  try{await sbDelete('addon_requests','id=eq.'+id);loadAddonRequests();}catch(e){alert('Could not delete: '+e.message);}
}
async function updateAdmissionStatus(id,status){
  try{await sbPatch('admissions','id=eq.'+id,{status:status});}catch(e){alert('Could not update status: '+e.message);}
}
async function deleteAdmission(id){
  if(!confirm('Delete this admission inquiry?'))return;
  try{await sbDelete('admissions','id=eq.'+id);loadAdmissions();}catch(e){alert('Could not delete: '+e.message);}
}

// ============================================================
// EXAM TIMETABLE
// ============================================================
async function addExamEntry(){
  var cls=document.getElementById('ex-class').value.trim();
  var subject=document.getElementById('ex-subject').value.trim();
  var date=document.getElementById('ex-date').value;
  var time=document.getElementById('ex-time').value.trim();
  var term=document.getElementById('ex-term').value;
  var year=document.getElementById('ex-year').value.trim();
  if(!cls||!subject){alert('Class and subject are required.');return;}
  try{
    await sbPost('exam_timetable',{class_arm:cls,subject:subject,date:date||null,time:time,term:term,year:year});
    alert('Added to timetable.');
    document.getElementById('ex-subject').value='';document.getElementById('ex-date').value='';document.getElementById('ex-time').value='';
    loadAdminExamList();
  }catch(e){alert('Could not add: '+e.message);}
}
async function addExamEntryVA(){
  var cls=document.getElementById('va-ex-class').value.trim();
  var subject=document.getElementById('va-ex-subject').value.trim();
  var date=document.getElementById('va-ex-date').value;
  var time=document.getElementById('va-ex-time').value.trim();
  var term=document.getElementById('va-ex-term').value;
  var year=document.getElementById('va-ex-year').value.trim();
  if(!cls||!subject){alert('Class and subject are required.');return;}
  try{
    await sbPost('exam_timetable',{class_arm:cls,subject:subject,date:date||null,time:time,term:term,year:year});
    alert('Added to timetable.');
    document.getElementById('va-ex-subject').value='';document.getElementById('va-ex-date').value='';document.getElementById('va-ex-time').value='';
    loadVaExamList();
  }catch(e){alert('Could not add: '+e.message);}
}
async function loadAdminExamList(){
  var el=document.getElementById('admin-exam-list');
  try{
    var rows=await sbGet('exam_timetable?order=date.asc');
    el.innerHTML=renderDecorativeTimetable(rows,'Dpride International School','Full Examination Timetable \u2014 All Classes');
    loadAdminExamManage(rows);
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load timetable.</div>';}
}
function loadAdminExamManage(rows){
  var el=document.getElementById('admin-exam-manage');
  if(!rows.length){el.innerHTML='<div class="empty-txt">Nothing to manage yet.</div>';return;}
  el.innerHTML=rows.map(function(r){
    return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(r.subject)+' \u2014 '+esc(r.class_arm)+'</div><div class="lb-sub">'+(r.date?new Date(r.date).toLocaleDateString('en-GB'):'')+' '+esc(r.time||'')+'</div></div><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteExamEntry(\''+r.id+'\')">Delete</button></div>';
  }).join('');
}
async function deleteExamEntry(id){
  if(!confirm('Delete this exam entry?'))return;
  try{await sbDelete('exam_timetable','id=eq.'+id);loadAdminExamList();}catch(e){alert('Could not delete: '+e.message);}
}

// ============================================================
// SCHOOL CALENDAR (Admin & Virtual Assistant can add; Admin can delete)
// ============================================================
async function addCalendarEvent(){
  var title=document.getElementById('cal-title').value.trim();
  var date=document.getElementById('cal-date').value;
  var time=document.getElementById('cal-time').value.trim();
  var desc=document.getElementById('cal-desc').value.trim();
  var aud=document.getElementById('cal-audience').value;
  if(!title){alert('Enter an event title.');return;}
  try{
    await sbPost('school_calendar',{title:title,date:date||null,time:time,description:desc,audience:aud});
    alert('Added to calendar.');
    document.getElementById('cal-title').value='';document.getElementById('cal-date').value='';document.getElementById('cal-time').value='';document.getElementById('cal-desc').value='';
    loadAdminCalendar();
  }catch(e){alert('Could not add: '+e.message);}
}
async function addCalendarEventVA(){
  var title=document.getElementById('va-cal-title').value.trim();
  var date=document.getElementById('va-cal-date').value;
  var time=document.getElementById('va-cal-time').value.trim();
  var desc=document.getElementById('va-cal-desc').value.trim();
  var aud=document.getElementById('va-cal-audience').value;
  if(!title){alert('Enter an event title.');return;}
  try{
    await sbPost('school_calendar',{title:title,date:date||null,time:time,description:desc,audience:aud});
    alert('Added to calendar.');
    document.getElementById('va-cal-title').value='';document.getElementById('va-cal-date').value='';document.getElementById('va-cal-time').value='';document.getElementById('va-cal-desc').value='';
    loadVaCalendar();
  }catch(e){alert('Could not add: '+e.message);}
}
async function loadAdminCalendar(){
  var el=document.getElementById('admin-calendar-list');
  try{
    var rows=await sbGet('school_calendar?order=date.asc');
    el.innerHTML=renderDecorativeCalendar(rows,'Dpride International School','School Calendar \u2014 All Events');
    loadAdminCalendarManage(rows);
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load calendar.</div>';}
}
function loadAdminCalendarManage(rows){
  var el=document.getElementById('admin-calendar-manage');
  if(!rows.length){el.innerHTML='<div class="empty-txt">Nothing to manage yet.</div>';return;}
  el.innerHTML=rows.map(function(r){
    return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(r.title)+'</div><div class="lb-sub">'+(r.date?new Date(r.date).toLocaleDateString('en-GB'):'')+' '+esc(r.time||'')+' \u00b7 '+esc(r.audience)+'</div></div><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteCalendarEvent(\''+r.id+'\')">Delete</button></div>';
  }).join('');
}
async function deleteCalendarEvent(id){
  if(!confirm('Delete this calendar event?'))return;
  try{await sbDelete('school_calendar','id=eq.'+id);loadAdminCalendar();}catch(e){alert('Could not delete: '+e.message);}
}
async function loadReadOnlyCalendar(targetId,cardId,audience){
  var el=document.getElementById(targetId);
  if(!el)return;
  try{
    var rows=await sbGet('school_calendar?audience=in.(all,'+audience+')&order=date.asc');
    if(!rows.length)return;
    el.innerHTML=renderDecorativeCalendar(rows,'Dpride International School','School Calendar');
    if(cardId)document.getElementById(cardId).style.display='block';
  }catch(e){}
}
function renderDecorativeCalendar(rows,title,subtitle){
  if(!rows.length)return '<div class="empty-txt">No events yet.</div>';
  var groups={};
  rows.forEach(function(r){var d=r.date||'tbc';if(!groups[d])groups[d]=[];groups[d].push(r);});
  var dates=Object.keys(groups).sort();
  var body=dates.map(function(d){
    var items=groups[d];
    var dow='',dnum='?',dlabel='Date to be confirmed';
    if(d!=='tbc'){
      var dt=new Date(d+'T00:00:00');
      dow=dt.toLocaleDateString('en-GB',{weekday:'short'});
      dnum=dt.getDate();
      dlabel=dt.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
    }
    var rowsHtml=items.map(function(r){
      return '<div class="tt-row"><span class="tt-subj-ic">\ud83d\udcc5</span><div style="flex:1;"><div class="tt-subj-name">'+esc(r.title)+'</div>'+(r.description?'<div class="tt-subj-class">'+esc(r.description)+'</div>':'')+'</div>'+(r.time?'<span class="tt-subj-time">'+esc(r.time)+'</span>':'')+'</div>';
    }).join('');
    return '<div class="tt-daygroup"><div class="tt-day-hd"><div class="tt-day-badge"><span class="dow">'+dow+'</span><span class="dnum">'+dnum+'</span></div><div><div class="tt-day-label">'+dlabel+'</div><div class="tt-day-sub">'+items.length+' event'+(items.length>1?'s':'')+'</div></div></div>'+rowsHtml+'</div>';
  }).join('');
  return '<div class="tt-wrap"><div class="tt-banner"><div class="tt-banner-crest">D</div><div class="tt-banner-title">'+esc(title)+'</div><div class="tt-banner-sub">'+esc(subtitle)+'</div></div><div class="tt-body">'+body+'</div></div>';
}

// ============================================================
// RESULTS (teacher submits → admin/principal approves → parent sees)
// ============================================================
</script>
</body>
</html>
