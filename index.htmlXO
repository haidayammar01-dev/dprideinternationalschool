<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dpride International School — Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#1B3A6B;--navy-deep:#0F2347;--navy-light:#2A4F8F;
  --gold:#C9A84C;--gold-light:#E8C96A;
  --white:#FFFFFF;--off:#EAF0FA;--blue-tint:#DCE6F5;
  --text:#1a1a2e;--muted:#5b6a85;--border:#c9d6ec;
  --green:#166534;--green-bg:#dcfce7;
  --warn:#92400e;--warn-bg:#fef3c7;
  --red:#991b1b;--red-bg:#fef2f2;
  --r:10px;--rlg:16px;--sh:0 4px 18px rgba(15,35,71,0.12);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  font-family:'DM Sans',Arial,sans-serif;color:var(--text);min-height:100vh;
  background:
    radial-gradient(1200px 500px at 50% -10%, rgba(27,58,107,0.10), transparent),
    linear-gradient(180deg, var(--navy-deep) 0px, var(--navy-deep) 210px, var(--off) 210px, var(--off) 100%);
  background-attachment:fixed;
}
.hdr{background:var(--navy-deep);position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,0.3);border-bottom:3px solid var(--gold);}
.hdr-in{max-width:980px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:64px;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-mk{width:38px;height:38px;background:linear-gradient(135deg,var(--gold-light),var(--gold));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--navy-deep);box-shadow:0 2px 8px rgba(201,168,76,0.4);}
.logo-tx{font-size:15px;font-weight:600;color:#fff;line-height:1.3;}
.logo-sub{font-size:11px;color:var(--gold-light);}
.hdr-r{display:flex;align-items:center;gap:10px;}
.logout-btn{background:none;border:1px solid rgba(255,255,255,0.25);border-radius:8px;cursor:pointer;color:rgba(255,255,255,0.75);font-size:13px;padding:7px 15px;font-family:'DM Sans',sans-serif;}
.logout-btn:hover{color:var(--navy-deep);background:var(--gold-light);border-color:var(--gold-light);}
.main{max-width:980px;margin:0 auto;padding:28px 20px 80px;}

.card{background:var(--white);border-radius:var(--rlg);box-shadow:var(--sh);margin-bottom:20px;overflow:hidden;border:1px solid rgba(27,58,107,0.08);border-top:4px solid var(--gold);}
.card-hd{padding:16px 22px;border-bottom:1px solid var(--border);font-size:15px;font-weight:700;color:#fff;background:linear-gradient(135deg,var(--navy),var(--navy-deep));letter-spacing:.01em;}
.card-bd{padding:22px;}

.fee-hero{background:linear-gradient(135deg,var(--navy-deep),var(--navy) 60%,var(--navy-light));border-radius:var(--rlg);padding:28px 26px;color:#fff;margin-bottom:20px;box-shadow:0 8px 28px rgba(15,35,71,0.35);border:1px solid rgba(201,168,76,0.35);}
.fee-hero-lbl{font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,0.65);margin-bottom:6px;}
.fee-hero-amt{font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:var(--gold-light);}
.fee-hero-amt.zero{color:#86efac;}
.fee-meter{margin-top:18px;background:rgba(255,255,255,0.14);border-radius:20px;height:18px;overflow:hidden;border:1px solid rgba(255,255,255,0.15);}
.fee-meter-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-light));border-radius:20px;transition:width .6s ease;box-shadow:0 0 12px rgba(232,201,106,0.6);}
.fee-meter-lbl{margin-top:9px;font-size:12px;color:rgba(255,255,255,0.75);display:flex;justify-content:space-between;}

.notice-card{padding:14px 0;border-bottom:1px solid var(--border);}
.notice-card:last-child{border-bottom:none;}
.notice-title{font-size:14px;font-weight:700;color:var(--navy);}
.notice-body{font-size:13px;color:var(--text);margin-top:4px;line-height:1.5;}
.notice-date{font-size:11px;color:var(--muted);margin-top:6px;}

.lb-week{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--navy);margin-bottom:10px;padding-bottom:8px;border-bottom:2px solid var(--gold);}
.lb-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.lb-row:last-child{border-bottom:none;}
.lb-rank{font-family:'Playfair Display',serif;font-weight:700;color:var(--gold);font-size:16px;width:30px;}
.lb-info{flex:1;}
.lb-name{font-size:13px;font-weight:700;color:var(--text);}
.lb-sub{font-size:11px;color:var(--muted);}
.lb-score{font-size:14px;font-weight:700;color:var(--navy);background:var(--blue-tint);padding:3px 10px;border-radius:20px;}

.sbee-week{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:6px;}
.sbee-name{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--navy);}
.sbee-sub{font-size:12px;color:var(--muted);margin-top:4px;}

.loading-txt,.empty-txt{font-size:13px;color:var(--muted);padding:6px 0;}

.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px;}
.fg label{font-size:11px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:.06em;}
.fg input,.fg select,.fg textarea{padding:10px 13px;font-size:14px;font-family:'DM Sans',sans-serif;border:1.5px solid var(--border);border-radius:var(--r);background:var(--white);color:var(--text);width:100%;}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--navy-light);}
.btn{padding:11px 20px;font-size:14px;font-weight:600;border:none;border-radius:var(--r);cursor:pointer;font-family:'DM Sans',sans-serif;background:var(--navy);color:#fff;}
.btn:hover{background:var(--navy-light);}
.btn.gold{background:linear-gradient(135deg,var(--gold-light),var(--gold));color:var(--navy-deep);font-weight:700;}
.btn.gold:hover{filter:brightness(1.05);}
.btn.sm{padding:7px 14px;font-size:12px;}
.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;}
.tab-btn{padding:9px 18px;font-size:13px;font-weight:600;border:1.5px solid var(--navy);border-radius:20px;cursor:pointer;background:var(--white);color:var(--navy);}
.tab-btn.on{background:var(--navy);border-color:var(--navy);color:#fff;}
.flag-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.flag-badge{font-size:10px;font-weight:700;background:var(--red-bg);color:var(--red);padding:3px 9px;border-radius:20px;}

.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;
  background:
    radial-gradient(900px 500px at 50% 0%, rgba(201,168,76,0.10), transparent),
    linear-gradient(160deg,var(--navy-deep),var(--navy) 55%,var(--navy-light));
}
.login-card{background:#fff;border-radius:var(--rlg);box-shadow:0 20px 60px rgba(0,0,0,0.35);padding:38px 32px;max-width:400px;width:100%;text-align:center;border-top:5px solid var(--gold);animation:fadeSlideUp .5s ease both;}
.login-logo{width:60px;height:60px;background:linear-gradient(135deg,var(--gold-light),var(--gold));border-radius:14px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:var(--navy-deep);margin:0 auto 16px;box-shadow:0 4px 16px rgba(201,168,76,0.4);position:relative;overflow:hidden;animation:logoPop .7s cubic-bezier(.34,1.56,.64,1) both;}
.login-logo::after{content:'';position:absolute;top:0;left:-60%;width:40%;height:100%;background:linear-gradient(120deg,transparent,rgba(255,255,255,0.65),transparent);animation:shimmer 2.6s ease-in-out .8s infinite;}
.login-title{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--navy);animation:fadeSlideUp .6s ease .15s both;}
.login-sub{font-size:13px;color:var(--muted);margin:4px 0 24px;animation:fadeSlideUp .6s ease .3s both;}
@keyframes logoPop{0%{transform:scale(0.3) rotate(-8deg);opacity:0;}100%{transform:scale(1) rotate(0deg);opacity:1;}}
@keyframes shimmer{0%{left:-60%;}100%{left:130%;}}
@keyframes fadeSlideUp{0%{opacity:0;transform:translateY(10px);}100%{opacity:1;transform:translateY(0);}}
@keyframes fadeIn{0%{opacity:0;}100%{opacity:1;}}

/* Photo filmstrip on the login page */
.photo-strip-wrap{max-width:520px;width:100%;margin-top:26px;overflow:hidden;border-radius:var(--rlg);box-shadow:0 10px 30px rgba(0,0,0,0.25);animation:fadeIn 1s ease .4s both;position:relative;}
.photo-strip-wrap::before,.photo-strip-wrap::after{content:'';position:absolute;top:0;bottom:0;width:36px;z-index:2;pointer-events:none;}
.photo-strip-wrap::before{left:0;background:linear-gradient(90deg,rgba(15,35,71,0.9),transparent);}
.photo-strip-wrap::after{right:0;background:linear-gradient(-90deg,rgba(15,35,71,0.9),transparent);}
.photo-strip{display:flex;gap:12px;width:max-content;animation:scrollStrip 28s linear infinite;}
.photo-strip:hover{animation-play-state:paused;}
@keyframes scrollStrip{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.photo-card{width:150px;height:150px;border-radius:12px;flex-shrink:0;background-size:cover;background-position:center;box-shadow:0 4px 14px rgba(0,0,0,0.3);border:2px solid rgba(201,168,76,0.4);}
.photo-caption{text-align:center;font-size:11px;color:rgba(255,255,255,0.55);margin-top:10px;animation:fadeIn 1s ease .6s both;}
.login-input{width:100%;padding:14px 16px;font-size:18px;letter-spacing:.08em;text-align:center;border:1.5px solid var(--border);border-radius:var(--r);margin-bottom:14px;text-transform:uppercase;}
.login-input:focus{outline:none;border-color:var(--navy-light);}
.login-err{font-size:12px;color:var(--red);margin-bottom:10px;min-height:16px;}
/* Decorative Exam Timetable */
.tt-wrap{border-radius:var(--rlg);overflow:hidden;box-shadow:0 6px 24px rgba(15,35,71,0.15);border:1px solid rgba(201,168,76,0.3);}
.tt-banner{background:linear-gradient(135deg,var(--navy-deep),var(--navy) 60%,var(--navy-light));padding:22px 24px;text-align:center;position:relative;overflow:hidden;}
.tt-banner::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--gold),var(--gold-light),var(--gold));}
.tt-banner-crest{width:42px;height:42px;background:linear-gradient(135deg,var(--gold-light),var(--gold));border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--navy-deep);margin:0 auto 8px;box-shadow:0 3px 10px rgba(201,168,76,0.4);}
.tt-banner-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#fff;letter-spacing:.01em;}
.tt-banner-sub{font-size:11px;color:var(--gold-light);text-transform:uppercase;letter-spacing:.1em;margin-top:4px;}
.tt-body{background:#fff;padding:18px 20px;}
.tt-daygroup{margin-bottom:18px;}
.tt-daygroup:last-child{margin-bottom:0;}
.tt-day-hd{display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.tt-day-badge{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,var(--navy),var(--navy-light));color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 3px 8px rgba(27,58,107,0.3);}
.tt-day-badge .dow{font-size:9px;text-transform:uppercase;letter-spacing:.05em;opacity:.8;line-height:1;}
.tt-day-badge .dnum{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;line-height:1.2;}
.tt-day-label{font-size:13px;font-weight:700;color:var(--navy);}
.tt-day-sub{font-size:11px;color:var(--muted);}
.tt-row{display:flex;align-items:center;gap:12px;padding:10px 14px 10px 56px;border-left:3px solid var(--gold);background:var(--off);border-radius:8px;margin-bottom:6px;}
.tt-row:nth-child(even){background:var(--blue-tint);}
.tt-subj-ic{font-size:16px;}
.tt-subj-name{font-size:13px;font-weight:600;color:var(--text);flex:1;}
.tt-subj-class{font-size:11px;color:var(--muted);}
.tt-subj-time{font-size:12px;font-weight:700;color:var(--navy);background:#fff;padding:4px 10px;border-radius:20px;border:1px solid var(--border);}
</style>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
</head>
<body>

<!-- ============ LOGIN VIEW ============ -->
<div id="view-login" class="login-wrap" style="flex-direction:column;">
  <div class="login-card">
    <div class="login-logo">D</div>
    <div class="login-title">Dpride International School</div>
    <div class="login-sub">Groom Them Young &middot; enter your access code</div>
    <input id="code" class="login-input" placeholder="ACCESS CODE" maxlength="20" autocomplete="off" oninput="this.value=this.value.toUpperCase();" />
    <div id="err" class="login-err"></div>
    <button class="btn gold" style="width:100%;" onclick="tryLogin()">Log In</button>
    <div style="font-size:11px;color:var(--muted);margin-top:16px;">Everyone — parents, teachers, and admin — logs in here with the code given to you by the school office.</div>
    <div class="back-link" style="margin-top:10px;" onclick="openAdmissionsForm()">New family? Apply for admission →</div>
  </div>

  <div id="admissions-modal" style="display:none;position:fixed;inset:0;background:rgba(15,35,71,0.7);z-index:200;align-items:center;justify-content:center;padding:20px;">
    <div class="login-card" style="max-width:440px;text-align:left;">
      <div class="login-title" style="text-align:center;">Apply for Admission</div>
      <div class="login-sub" style="text-align:center;">Tell us about your child — we'll be in touch shortly.</div>
      <div class="fg"><label>Child's Full Name</label><input id="adm-name" /></div>
      <div class="fg"><label>Date of Birth</label><input id="adm-dob" type="date" /></div>
      <div class="fg"><label>Level Applying For</label>
        <select id="adm-level"><option value="creche">Crèche</option><option value="nursery">Nursery</option><option value="primary">Primary</option></select>
      </div>
      <div class="fg"><label>Parent / Guardian Name</label><input id="adm-parent" /></div>
      <div class="fg"><label>Phone</label><input id="adm-phone" /></div>
      <div class="fg"><label>Email (optional)</label><input id="adm-email" /></div>
      <div class="fg"><label>Anything else we should know?</label><textarea id="adm-notes" rows="3"></textarea></div>
      <div id="adm-msg" style="font-size:12px;color:var(--green);margin-bottom:10px;"></div>
      <button class="btn gold" style="width:100%;" onclick="submitAdmission()">Submit Application</button>
      <div class="back-link" style="text-align:center;margin-top:10px;" onclick="closeAdmissionsForm()">← Back to login</div>
    </div>
  </div>

  <div class="photo-strip-wrap">
    <div class="photo-strip" id="photo-strip">
      <div class="photo-card" style="background-image:url('photos/1.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/2.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/3.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/4.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/5.jpg');"></div>
      <!-- duplicate set again so the scroll loops seamlessly -->
      <div class="photo-card" style="background-image:url('photos/1.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/2.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/3.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/4.jpg');"></div>
      <div class="photo-card" style="background-image:url('photos/5.jpg');"></div>
    </div>
  </div>
  <div class="photo-caption">Dpride International School — Groom Them Young</div>
</div>

<!-- ============ APP SHELL (shown after login) ============ -->
<div id="app-shell" style="display:none;">
  <div class="hdr"><div class="hdr-in">
    <div class="logo"><div class="logo-mk">D</div><div><div class="logo-tx">Dpride International School</div><div class="logo-sub" id="welcome-txt">Portal</div></div></div>
    <div class="hdr-r" id="hdr-extra">
      <img id="hdr-avatar" style="display:none;width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid var(--gold);" />
      <button class="logout-btn" onclick="doLogout()">Log out</button>
    </div>
  </div></div>

  <div class="main">

    <!-- ===== PARENT VIEW ===== -->
    <div id="view-parent" style="display:none;">
      <div class="fee-hero" id="fee-hero">
        <div class="fee-hero-lbl">Outstanding Balance — <span id="fee-term-lbl"></span></div>
        <div class="fee-hero-amt" id="fee-amt">Loading…</div>
        <div class="fee-meter"><div class="fee-meter-fill" id="fee-fill" style="width:0%;"></div></div>
        <div class="fee-meter-lbl"><span id="fee-paid-lbl"></span><span id="fee-goal-lbl"></span></div>
      </div>
      <div class="card" id="fee-bychild-card" style="display:none;">
        <div class="card-hd">Fees by Child — <span id="fee-bychild-term"></span></div>
        <div class="card-bd" id="fee-bychild-list"></div>
      </div>
      <div class="card" id="addons-card"><div class="card-hd">Optional Add-ons</div><div class="card-bd">
        <p style="font-size:13px;color:var(--muted);margin-bottom:12px;">Tick any optional services you'd like — your total below updates instantly. Submitting sends your request to the school office.</p>
        <div id="addons-list"><div class="loading-txt">Loading…</div></div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px;padding-top:12px;border-top:2px solid var(--gold);">
          <div style="font-size:13px;font-weight:700;color:var(--navy);">Total with add-ons</div>
          <div id="addons-total" style="font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--navy);">—</div>
        </div>
        <button class="btn gold" style="margin-top:12px;" onclick="submitAddons()">Send Add-on Request to School</button>
        <div id="addons-msg" style="margin-top:8px;font-size:12px;"></div>
      </div></div>
      <div class="card"><div class="card-hd">Your Children</div><div class="card-bd" id="children-list"><div class="loading-txt">Loading…</div></div></div>
      <div class="card" id="teachers-card" style="display:none;"><div class="card-hd">Your Children's Teachers</div><div class="card-bd" id="child-teachers-list"></div></div>
      <div class="card" id="exam-tt-card" style="display:none;"><div class="card-hd">Exam Timetable</div><div class="card-bd" id="exam-tt-list"></div></div>
      <div class="card" id="p-calendar-card" style="display:none;"><div class="card-hd">School Calendar</div><div class="card-bd" id="p-calendar-list"></div></div>
      <div class="card"><div class="card-hd">⭐ Spelling Bee — Star of the Week</div><div class="card-bd" id="p-spelling-bee"></div></div>
      <div class="card"><div class="card-hd">🏆 Best Student Leaderboard</div><div class="card-bd" id="p-student-lb"></div></div>
      <div class="card" id="inspection-card" style="display:none;"><div class="card-hd">Grooming & Uniform Inspection</div><div class="card-bd" id="inspection-list"></div></div>
      <div class="card"><div class="card-hd">📢 Notice Board</div><div class="card-bd" id="p-notice-board"></div></div>
    </div>

    <!-- ===== TEACHER VIEW ===== -->
    <div id="view-teacher" style="display:none;">
      <div class="tabs">
        <div class="tab-btn on" onclick="showTeacherTab('attendance',this)">Attendance</div>
        <div class="tab-btn" onclick="showTeacherTab('inspection',this)">Inspection</div>
        <div class="tab-btn" onclick="showTeacherTab('board',this)">Boards & Notices</div>
        <div class="tab-btn" onclick="showTeacherTab('profile',this)">My Profile</div>
      </div>
      <div id="tt-attendance" class="tt-pane">
        <div class="card"><div class="card-hd">Take Attendance</div><div class="card-bd">
          <div class="fg"><label>Class</label><input id="att-class" placeholder="e.g. Primary 4B" /></div>
          <div class="fg"><label>Date</label><input id="att-date" type="date" /></div>
          <button class="btn" onclick="loadAttClass()">Load Class</button>
          <div id="att-roster" style="margin-top:16px;"></div>
        </div></div>
        <div class="card"><div class="card-hd">⚠️ Flagged — Absent 2 of Last 3 Days</div><div class="card-bd" id="att-flags"><div class="loading-txt">Loading…</div></div></div>
      </div>
      <div id="tt-inspection" class="tt-pane" style="display:none;">
        <div class="card"><div class="card-hd">Grooming & Uniform Inspection</div><div class="card-bd">
          <div class="fg"><label>Class</label><input id="ins-class" placeholder="e.g. Primary 4B" /></div>
          <div class="fg"><label>Date</label><input id="ins-date" type="date" /></div>
          <button class="btn" onclick="loadInsClass()">Load Class</button>
          <div id="ins-roster" style="margin-top:16px;"></div>
        </div></div>
      </div>
      <div id="tt-board" class="tt-pane" style="display:none;">
        <div class="card"><div class="card-hd">🏆 Best Teacher Leaderboard</div><div class="card-bd" id="t-teacher-lb"></div></div>
        <div class="card"><div class="card-hd">🏆 Best Student Leaderboard</div><div class="card-bd" id="t-student-lb"></div></div>
        <div class="card"><div class="card-hd">⭐ Spelling Bee — Star of the Week</div><div class="card-bd" id="t-spelling-bee"></div></div>
        <div class="card"><div class="card-hd">📢 Notice Board</div><div class="card-bd" id="t-notice-board"></div></div>
