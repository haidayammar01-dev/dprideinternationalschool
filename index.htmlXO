// VIRTUAL ASSISTANT (no financial access — roster, bookings, notices only)
// ============================================================
function initAssistant(){
  loadVaRoster();
  renderNoticeBoard('va-notice-board','all');
  loadVaExamList();
  loadVaCalendar();
}
