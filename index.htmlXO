</div>

<script>
var SUPABASE_URL='https://iiryurxycyhjcriefhau.supabase.co';
var FEES_PORTAL_HTML_B64='';
var SUPABASE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imlpcnl1cnh5Y3loamNyaWVmaGF1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA0MDIxODIsImV4cCI6MjA5NTk3ODE4Mn0.EUbX_92s-qS9VwePS5aLNfB2z1-oV13a8Ju7KHjj_dI';
// Reuses the same EmailJS account already wired up in the Fees Portal
var EMAILJS_SVC='service_2ax69md';
var EMAILJS_TPL='template_o9auj2i';
var EMAILJS_KEY='o973UL7wlFM7lICww';
var SCHOOL_EMAIL='dprideinternationalschool1@gmail.com';
async function sendAdmissionEmail(a){
  try{
    emailjs.init(EMAILJS_KEY);
    var msg='NEW ADMISSION INQUIRY\n'
      +'Child: '+a.applicant_name+' (DOB: '+(a.dob||'not given')+')\n'
      +'Applying for: '+a.level_applying+'\n'
      +'Parent/Guardian: '+a.parent_name+'\n'
      +'Phone: '+a.phone+'\n'
      +'Email: '+(a.email||'not given')+'\n'
      +(a.notes?'Notes: '+a.notes+'\n':'')
      +'Submitted: '+new Date().toLocaleString('en-GB');
    await emailjs.send(EMAILJS_SVC,EMAILJS_TPL,{message:msg,to_email:SCHOOL_EMAIL});
  }catch(e){console.warn('Admission email failed:',e);}
}

function sbHeaders(extra){return Object.assign({'Content-Type':'application/json','apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY},extra||{});}
async function sbGet(path){var r=await fetch(SUPABASE_URL+'/rest/v1/'+path,{headers:sbHeaders()});if(!r.ok)throw new Error('GET '+path+' failed: '+r.status);return r.json();}
async function sbPost(table,row){var r=await fetch(SUPABASE_URL+'/rest/v1/'+table,{method:'POST',headers:sbHeaders({'Prefer':'return=representation'}),body:JSON.stringify(row)});if(!r.ok){var t=await r.text();throw new Error('POST '+table+' failed: '+r.status+' '+t);}return r.json();}
async function sbPatch(table,filter,row){var r=await fetch(SUPABASE_URL+'/rest/v1/'+table+'?'+filter,{method:'PATCH',headers:sbHeaders({'Prefer':'return=representation'}),body:JSON.stringify(row)});if(!r.ok){var t=await r.text();throw new Error('PATCH '+table+' failed: '+r.status+' '+t);}return r.json();}
async function sbDelete(table,filter){var r=await fetch(SUPABASE_URL+'/rest/v1/'+table+'?'+filter,{method:'DELETE',headers:sbHeaders()});if(!r.ok){var t=await r.text();throw new Error('DELETE '+table+' failed: '+r.status+' '+t);}}
async function sbUploadPhoto(file,keyHint){
  var ext=(file.name.split('.').pop()||'jpg').toLowerCase();
  var path=keyHint+'-'+Date.now()+'.'+ext;
  var r=await fetch(SUPABASE_URL+'/storage/v1/object/profile-photos/'+path,{
    method:'POST',
    headers:{'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY,'Content-Type':file.type||'image/jpeg'},
    body:file
  });
  if(!r.ok){var t=await r.text();throw new Error('Photo upload failed: '+r.status+' '+t);}
  return SUPABASE_URL+'/storage/v1/object/public/profile-photos/'+path;
}

function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
function fmtN(n){return '\u20a6'+Math.round(Number(n)||0).toLocaleString();}

// ── Session ──
function getSession(){try{return JSON.parse(sessionStorage.getItem('dpride_session')||'null');}catch(e){return null;}}
function setSession(o){sessionStorage.setItem('dpride_session',JSON.stringify(o));}
function clearSession(){sessionStorage.removeItem('dpride_session');}
function doLogout(){clearSession();location.reload();}

var session=null;

// ── Boot ──
window.addEventListener('DOMContentLoaded',function(){
  session=getSession();
  if(session){enterApp();}
  document.getElementById('code').addEventListener('keydown',function(e){if(e.key==='Enter')tryLogin();});
});

function openAdmissionsForm(){document.getElementById('admissions-modal').style.display='flex';}
function closeAdmissionsForm(){document.getElementById('admissions-modal').style.display='none';}
async function submitAdmission(){
  var name=document.getElementById('adm-name').value.trim();
  var dob=document.getElementById('adm-dob').value;
  var level=document.getElementById('adm-level').value;
  var parent=document.getElementById('adm-parent').value.trim();
  var phone=document.getElementById('adm-phone').value.trim();
  var email=document.getElementById('adm-email').value.trim();
  var notes=document.getElementById('adm-notes').value.trim();
  var msg=document.getElementById('adm-msg');
  if(!name||!parent||!phone){msg.style.color='var(--red)';msg.textContent='Please fill in the child\u2019s name, parent name, and phone.';return;}
  try{
    var admRec={applicant_name:name,dob:dob||null,level_applying:level,parent_name:parent,phone:phone,email:email,notes:notes};
    await sbPost('admissions',admRec);
    sendAdmissionEmail(admRec);
    msg.style.color='var(--green)';
    msg.textContent='Thank you! Your application has been received \u2014 the school office will contact you soon.';
    document.getElementById('adm-name').value='';document.getElementById('adm-parent').value='';document.getElementById('adm-phone').value='';document.getElementById('adm-email').value='';document.getElementById('adm-notes').value='';
  }catch(e){msg.style.color='var(--red)';msg.textContent='Could not submit right now \u2014 please try again.';}
}
async function tryLogin(){
  var code=document.getElementById('code').value.trim();
  var err=document.getElementById('err');
  err.textContent='';
  if(!code){err.textContent='Enter your code.';return;}
  try{
    var fam=await sbGet('families?code=ilike.'+encodeURIComponent(code)+'&select=*');
    if(fam.length){setSession({role:'parent',familyId:fam[0].id,code:fam[0].code,parentName:fam[0].parent_name});session=getSession();enterApp();return;}
    var tch=await sbGet('teachers?code=ilike.'+encodeURIComponent(code)+'&select=*');
    if(tch.length){setSession({role:'teacher',teacherId:tch[0].id,code:tch[0].code,teacherName:tch[0].name});session=getSession();enterApp();return;}
    var adm=await sbGet('admins?code=ilike.'+encodeURIComponent(code)+'&select=*');
    if(adm.length){setSession({role:'admin',adminId:adm[0].id,code:adm[0].code,adminName:adm[0].name});session=getSession();enterApp();return;}
    var va=await sbGet('assistants?code=ilike.'+encodeURIComponent(code)+'&select=*');
    if(va.length){setSession({role:'assistant',assistantId:va[0].id,code:va[0].code,assistantName:va[0].name});session=getSession();enterApp();return;}
    err.textContent='Code not recognised. Check with the school office.';
  }catch(e){err.textContent='Could not reach the portal. Check your connection and try again.';}
}

// The Fees Portal is a fully self-contained tool (own HTML/CSS/JS) embedded
// as base64 and loaded into an isolated iframe on demand, so it can never
// collide with the main portal's own variables, functions, or styles.
function openFeesPortal(){
  document.querySelectorAll('.at-pane, #view-parent, #view-teacher, #view-admin, #view-assistant').forEach(function(el){el.style.display='none';});
  document.getElementById('view-fees').style.display='block';
  var frame=document.getElementById('fees-frame');
  if(!frame.dataset.loaded){
    frame.srcdoc=atob(FEES_PORTAL_HTML_B64);
    frame.dataset.loaded='1';
  }
}
function closeFeesPortal(){
  document.getElementById('view-fees').style.display='none';
  document.getElementById('view-admin').style.display='block';
}
async function loadHeaderAvatar(table,idField,idVal){
  try{
    var rows=await sbGet(table+'?'+idField+'=eq.'+idVal+'&select=photo_url');
    if(rows.length&&rows[0].photo_url){
      var img=document.getElementById('hdr-avatar');
      img.src=rows[0].photo_url;img.style.display='inline-block';
    }
  }catch(e){}
}
function enterApp(){
  document.getElementById('view-login').style.display='none';
  document.getElementById('app-shell').style.display='block';
  document.getElementById('view-parent').style.display='none';
  document.getElementById('view-teacher').style.display='none';
  document.getElementById('view-admin').style.display='none';
  document.getElementById('view-assistant').style.display='none';

  if(session.role==='parent'){
    document.getElementById('welcome-txt').textContent=session.parentName?('Welcome, '+session.parentName):'Parent Portal';
    document.getElementById('view-parent').style.display='block';
    initParent();
    loadHeaderAvatar('families','id',session.familyId);
  }else if(session.role==='teacher'){
    document.getElementById('welcome-txt').textContent=session.teacherName?('Welcome, '+session.teacherName):'Teacher Portal';
    document.getElementById('view-teacher').style.display='block';
    initTeacher();
    loadHeaderAvatar('teachers','id',session.teacherId);
  }else if(session.role==='admin'){
    document.getElementById('welcome-txt').textContent=session.adminName?('Welcome, '+session.adminName):'Admin Console';
    document.getElementById('view-admin').style.display='block';
    initAdmin();
  }else if(session.role==='assistant'){
    document.getElementById('welcome-txt').textContent=session.assistantName?('Welcome, '+session.assistantName):'Virtual Assistant';
    document.getElementById('view-assistant').style.display='block';
    initAssistant();
  }
}

// ============================================================
// SHARED WIDGETS
// ============================================================
async function renderNoticeBoard(containerId,audience,editable){
  var el=document.getElementById(containerId);if(!el)return;
  el.innerHTML='<div class="loading-txt">Loading notices\u2026</div>';
  try{
    var rows=await sbGet('notices?audience=in.(all,'+audience+')&order=created_at.desc&limit=15');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No notices yet.</div>';return;}
    el.innerHTML=rows.map(function(n){
      var delBtn=editable?'<button class="btn sm" style="float:right;background:var(--red-bg);color:var(--red);" onclick="deleteNotice(\''+n.id+'\',\''+containerId+'\',\''+audience+'\')">Delete</button>':'';
      return '<div class="notice-card">'+delBtn+'<div class="notice-title">'+esc(n.title)+'</div>'+(n.body?'<div class="notice-body">'+esc(n.body)+'</div>':'')+'<div class="notice-date">'+new Date(n.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})+'</div></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load notices.</div>';}
}
async function deleteNotice(id,containerId,audience){
  if(!confirm('Delete this notice?'))return;
  try{await sbDelete('notices','id=eq.'+id);renderNoticeBoard(containerId,audience,true);}catch(e){alert('Could not delete: '+e.message);}
}
async function renderStudentLeaderboard(containerId){
  var el=document.getElementById(containerId);if(!el)return;
  el.innerHTML='<div class="loading-txt">Loading\u2026</div>';
  try{
    var rows=await sbGet('leaderboard_students?order=created_at.desc&limit=10');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No leaderboard entries yet.</div>';return;}
    var latestWeek=rows[0].week_label;
    var thisWeek=rows.filter(function(r){return r.week_label===latestWeek;});
    el.innerHTML='<div class="lb-week">'+esc(latestWeek||'')+'</div>'+thisWeek.map(function(r,i){
      return '<div class="lb-row"><span class="lb-rank">#'+(i+1)+'</span><div class="lb-info"><div class="lb-name">'+esc(r.student_name)+'</div><div class="lb-sub">'+esc(r.class||'')+(r.note?' \u00b7 '+esc(r.note):'')+'</div></div>'+(r.score!=null?'<div class="lb-score">'+esc(r.score)+'</div>':'')+'</div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load leaderboard.</div>';}
}
async function renderTeacherLeaderboard(containerId){
  var el=document.getElementById(containerId);if(!el)return;
  el.innerHTML='<div class="loading-txt">Loading\u2026</div>';
  try{
    var rows=await sbGet('leaderboard_teachers?order=created_at.desc&limit=10');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No leaderboard entries yet.</div>';return;}
    var latestMonth=rows[0].month_label;
    var thisMonth=rows.filter(function(r){return r.month_label===latestMonth;});
    el.innerHTML='<div class="lb-week">'+esc(latestMonth||'')+'</div>'+thisMonth.map(function(r,i){
      return '<div class="lb-row"><span class="lb-rank">#'+(i+1)+'</span><div class="lb-info"><div class="lb-name">'+esc(r.teacher_name)+'</div>'+(r.note?'<div class="lb-sub">'+esc(r.note)+'</div>':'')+'</div>'+(r.score!=null?'<div class="lb-score">'+esc(r.score)+'</div>':'')+'</div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load leaderboard.</div>';}
}
async function renderSpellingBee(containerId){
  var el=document.getElementById(containerId);if(!el)return;
  el.innerHTML='<div class="loading-txt">Loading\u2026</div>';
  try{
    var rows=await sbGet('spelling_bee?order=created_at.desc&limit=1');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No winner posted yet.</div>';return;}
    var r=rows[0];
    el.innerHTML='<div class="sbee-week">'+esc(r.week_label||'')+'</div><div class="sbee-name">\u2b50 '+esc(r.winner_name)+'</div><div class="sbee-sub">'+esc(r.class||'')+(r.word?' \u00b7 word: \u201c'+esc(r.word)+'\u201d':'')+'</div>';
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load.</div>';}
}

// ============================================================
// PARENT
// ============================================================
function initParent(){
  loadFees();loadChildren();
  renderSpellingBee('p-spelling-bee');
  renderStudentLeaderboard('p-student-lb');
  renderNoticeBoard('p-notice-board','parents');
  loadReadOnlyCalendar('p-calendar-list','p-calendar-card','parents');
}
// Optional add-ons: chosen PER CHILD. Each child gets their own checkboxes;
// submitting saves one request per child and emails the school office.
var ADDONS=[{k:'feeding',l:'School Feeding (per term)',a:300000},{k:'one2one',l:'One on One (per term)',a:150000},{k:'arabic',l:'Arabic Classes',a:30000},{k:'islamiyah',l:'Islamiyah After-School (4\u20136 pm)',a:40000}];
var _addonBase=0;
var _addonKids=[];
function loadAddons(kids){
  _addonKids=kids||[];
  var el=document.getElementById('addons-list');
  if(!_addonKids.length){el.innerHTML='<div class="empty-txt">Your children will appear here once the office adds them.</div>';return;}
  el.innerHTML=_addonKids.map(function(k,i){
    return '<div style="margin-bottom:14px;">'
      +'<div style="font-size:13px;font-weight:700;color:var(--navy);padding-bottom:6px;border-bottom:2px solid var(--gold);margin-bottom:4px;">'+esc(k.name)+'</div>'
      +ADDONS.map(function(a){
        return '<label class="flag-row" style="cursor:pointer;"><input type="checkbox" id="addon-'+i+'-'+a.k+'" onchange="recalcAddons()" style="width:18px;height:18px;accent-color:var(--navy);" /><div class="lb-info"><div class="lb-name">'+a.l+'</div></div><div class="lb-score">'+fmtN(a.a)+'</div></label>';
      }).join('')
      +'</div>';
  }).join('');
  recalcAddons();
}
function recalcAddons(){
  var sum=0;
  _addonKids.forEach(function(k,i){
    ADDONS.forEach(function(a){
      var cb=document.getElementById('addon-'+i+'-'+a.k);
      if(cb&&cb.checked)sum+=a.a;
    });
  });
  var el=document.getElementById('addons-total');
  if(el)el.textContent=fmtN(_addonBase+sum);
}
async function submitAddons(){
  var msg=document.getElementById('addons-msg');
  var perChild=[];
  _addonKids.forEach(function(k,i){
    var chosen=ADDONS.filter(function(a){var cb=document.getElementById('addon-'+i+'-'+a.k);return cb&&cb.checked;});
    if(chosen.length)perChild.push({child:k,addons:chosen});
  });
  if(!perChild.length){msg.style.color='var(--red)';msg.textContent='Tick at least one add-on first.';return;}
  try{
    var emailLines=[];
    for(var i=0;i<perChild.length;i++){
      var p=perChild[i];
      var total=p.addons.reduce(function(s,a){return s+a.a;},0);
      await sbPost('addon_requests',{family_code:session.code,child_name:p.child.name,addons:p.addons.map(function(a){return a.k;}),addons_total:total});
      emailLines.push(p.child.name+': '+p.addons.map(function(a){return a.l;}).join(', ')+' \u2014 \u20a6'+total.toLocaleString());
    }
    try{
      emailjs.init(EMAILJS_KEY);
      await emailjs.send(EMAILJS_SVC,EMAILJS_TPL,{message:'ADD-ON REQUEST (per child)\nFamily: '+session.code+' ('+(session.parentName||'')+')\n'+emailLines.join('\n')+'\nSubmitted: '+new Date().toLocaleString('en-GB'),to_email:SCHOOL_EMAIL});
    }catch(e2){}
    msg.style.color='var(--green)';msg.textContent='Request sent \u2014 the school office will confirm and update your invoice.';
  }catch(e){msg.style.color='var(--red)';msg.textContent='Could not send right now \u2014 please try again.';}
}
async function loadFees(){
  try{
    var state=await sbGet('school_state?id=eq.1&select=*');
    var yr=state[0]?state[0].current_year:'2026/2027';
    var term=state[0]?state[0].current_term:1;
    var termStr='Term '+term+' \u00b7 '+yr;
    document.getElementById('fee-term-lbl').textContent=termStr;
    var rows=await sbGet('payment_register?fcode=eq.'+encodeURIComponent(session.code)+'&term=eq.'+encodeURIComponent(termStr)+'&order=id.desc&limit=1');
    var amtEl=document.getElementById('fee-amt');
    if(!rows.length){
      amtEl.textContent='No invoice yet for this term';amtEl.classList.remove('zero');
      document.getElementById('fee-paid-lbl').textContent='';
      document.getElementById('fee-goal-lbl').textContent='Check back once the office generates it';
      return;
    }
    var r=rows[0];
    var balance=Number(r.balance||0),total=Number(r.total||0),paying=Number(r.paying||0);
    var pct=total>0?Math.min(100,Math.round(paying/total*100)):0;
    amtEl.textContent=fmtN(balance);amtEl.classList.toggle('zero',balance<=0);
    _addonBase=balance;if(document.getElementById('addons-total'))recalcAddons();
    document.getElementById('fee-fill').style.width=pct+'%';
    document.getElementById('fee-paid-lbl').textContent=fmtN(paying)+' paid';
    document.getElementById('fee-goal-lbl').textContent=pct+'% of '+fmtN(total);

    // Per-child breakdown (each child's own subtotal, from the invoice itself)
    var kids=r.children||[];
    if(kids.length){
      document.getElementById('fee-bychild-term').textContent=termStr;
      document.getElementById('fee-bychild-list').innerHTML=kids.map(function(c){
        return '<div class="lb-row"><div class="lb-info"><div class="lb-name">'+esc(c.name||'Child')+'</div><div class="lb-sub">'+esc(c.level||'')+(c.sType?' \u00b7 '+esc(c.sType):'')+'</div></div><div class="lb-score">'+fmtN(c.sub||0)+'</div></div>';
      }).join('')+'<div style="font-size:11px;color:var(--muted);margin-top:10px;">Individual amounts before any family or added discount. The combined total above (after discounts) is what\u2019s actually due.</div>';
      document.getElementById('fee-bychild-card').style.display='block';
    }
  }catch(e){document.getElementById('fee-amt').textContent='Could not load fees right now';}
}
async function loadChildren(){
  var el=document.getElementById('children-list');
  try{
    var kids=await sbGet('students?family_id=eq.'+session.familyId+'&select=*');
    if(!kids.length){el.innerHTML='<div class="empty-txt">No children on file yet \u2014 check with the office.</div>';return;}
    el.innerHTML=kids.map(function(k){return '<div class="lb-row"><div class="lb-info"><div class="lb-name">'+esc(k.name)+'</div><div class="lb-sub">'+esc(k.class_arm||k.level||'')+'</div></div></div>';}).join('');
    loadInspections(kids);
    loadChildTeachers(kids);
    loadAddons(kids);
    loadMyExamTimetable(kids);
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load children.</div>';}
}
async function loadMyExamTimetable(kids){
  try{
    var classes=[...new Set(kids.map(function(k){return k.class_arm;}).filter(Boolean))];
    if(!classes.length)return;
    var q='exam_timetable?class_arm=in.('+classes.map(function(c){return encodeURIComponent(c);}).join(',')+')&order=date.asc';
    var rows=await sbGet(q);
    if(!rows.length)return;
    document.getElementById('exam-tt-list').innerHTML=renderDecorativeTimetable(rows,'Examination Timetable','Your Child\u2019s Schedule');
    document.getElementById('exam-tt-card').style.display='block';
  }catch(e){}
}
// Shared decorative renderer — used by both the parent view and the admin view
function renderDecorativeTimetable(rows,title,subtitle){
  if(!rows.length)return '<div class="empty-txt">No exam entries yet.</div>';
  var subjectIcons={'english':'\ud83d\udcd6','maths':'\u2795','mathematics':'\u2795','science':'\ud83d\udd2c','basic science':'\ud83d\udd2c','social studies':'\ud83c\udf0d','quantitative':'\ud83d\udcca','verbal':'\ud83d\udcac','french':'\ud83c\uddeb\ud83c\uddf7','arabic':'\u262a\ufe0f','crs':'\u271d\ufe0f','irs':'\u262a\ufe0f','computer':'\ud83d\udcbb','ict':'\ud83d\udcbb','handwriting':'\u270d\ufe0f','phonics':'\ud83d\udd24','art':'\ud83c\udfa8','music':'\ud83c\udfb5','pe':'\u26bd','physical':'\u26bd'};
  function iconFor(subj){var k=(subj||'').toLowerCase();for(var key in subjectIcons){if(k.indexOf(key)>-1)return subjectIcons[key];}return '\ud83d\udcdd';}
  var groups={};
  rows.forEach(function(r){var d=r.date||'tbc';if(!groups[d])groups[d]=[];groups[d].push(r);});
  var dates=Object.keys(groups).sort();
  var body=dates.map(function(d){
    var items=groups[d];
    var dow='',dnum='?',dlabel='Date to be confirmed';
    if(d!=='tbc'){
      var dt=new Date(d+'T00:00:00');
      dow=dt.toLocaleDateString('en-GB',{weekday:'short'});
      dnum=dt.getDate();
      dlabel=dt.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
    }
    var rowsHtml=items.map(function(r){
      return '<div class="tt-row"><span class="tt-subj-ic">'+iconFor(r.subject)+'</span><div style="flex:1;"><div class="tt-subj-name">'+esc(r.subject)+'</div><div class="tt-subj-class">'+esc(r.class_arm||'')+(r.term?' \u00b7 Term '+esc(r.term):'')+'</div></div>'+(r.time?'<span class="tt-subj-time">'+esc(r.time)+'</span>':'')+'</div>';
    }).join('');
    return '<div class="tt-daygroup"><div class="tt-day-hd"><div class="tt-day-badge"><span class="dow">'+dow+'</span><span class="dnum">'+dnum+'</span></div><div><div class="tt-day-label">'+dlabel+'</div><div class="tt-day-sub">'+items.length+' subject'+(items.length>1?'s':'')+' scheduled</div></div></div>'+rowsHtml+'</div>';
  }).join('');
  return '<div class="tt-wrap"><div class="tt-banner"><div class="tt-banner-crest">D</div><div class="tt-banner-title">'+esc(title)+'</div><div class="tt-banner-sub">'+esc(subtitle)+'</div></div><div class="tt-body">'+body+'</div></div>';
}
async function loadInspections(kids){
  try{
    var ids=kids.map(function(k){return k.id;});if(!ids.length)return;
    var rows=await sbGet('inspections?student_id=in.('+ids.join(',')+')&order=date.desc&limit=20');
    if(!rows.length)return;
    var byStudent={};rows.forEach(function(r){if(!byStudent[r.student_id])byStudent[r.student_id]=r;});
    var kidMap={};kids.forEach(function(k){kidMap[k.id]=k.name;});
    var html=Object.keys(byStudent).map(function(sid){
      var r=byStudent[sid];
      return '<div class="lb-row"><div class="lb-info"><div class="lb-name">'+esc(kidMap[sid]||'Child')+'</div><div class="lb-sub">'+new Date(r.date).toLocaleDateString('en-GB')+(r.note?' \u00b7 '+esc(r.note):'')+'</div></div><div class="lb-score">'+esc(r.mark)+'</div></div>';
    }).join('');
    document.getElementById('inspection-list').innerHTML=html;
    document.getElementById('inspection-card').style.display='block';
  }catch(e){}
}

// ============================================================
// TEACHER
// ============================================================
function initTeacher(){
  document.getElementById('att-date').value=new Date().toISOString().slice(0,10);
  document.getElementById('ins-date').value=new Date().toISOString().slice(0,10);
  loadFlags('att-flags');
  renderTeacherLeaderboard('t-teacher-lb');
  renderStudentLeaderboard('t-student-lb');
  renderSpellingBee('t-spelling-bee');
  renderNoticeBoard('t-notice-board','teachers');
  loadReadOnlyCalendar('t-calendar-list',null,'teachers');
  loadProfile();
}
function showTeacherTab(name,btn){
  document.querySelectorAll('.tt-pane').forEach(function(p){p.style.display='none';});
  document.getElementById('tt-'+name).style.display='block';
  btn.parentElement.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
}
async function loadAttClass(){
  var cls=document.getElementById('att-class').value.trim();
  var el=document.getElementById('att-roster');
  if(!cls){alert('Enter a class name first.');return;}
  el.innerHTML='<div class="loading-txt">Loading roster\u2026</div>';
  try{
    var kids=await sbGet('students?class_arm=eq.'+encodeURIComponent(cls)+'&select=*&order=name.asc');
    if(!kids.length){el.innerHTML='<div class="empty-txt">No students found in that class.</div>';return;}
    el.innerHTML=kids.map(function(k){return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(k.name)+'</div></div><button class="btn sm" id="att-btn-'+k.id+'" data-status="present" onclick="toggleAtt(\''+k.id+'\')">Present</button></div>';}).join('')+'<button class="btn gold" style="margin-top:14px;" onclick="saveAttendance()">Save Attendance</button>';
    window._attKids=kids;
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load class.</div>';}
}
function toggleAtt(id){
  var b=document.getElementById('att-btn-'+id);
  var next=b.dataset.status==='present'?'absent':'present';
  b.dataset.status=next;b.textContent=next==='present'?'Present':'Absent';
  b.className='btn sm'+(next==='absent'?' gold':'');
}
async function saveAttendance(){
  var date=document.getElementById('att-date').value;
  if(!date||!window._attKids){alert('Load a class and pick a date first.');return;}
  try{
    for(var i=0;i<window._attKids.length;i++){
      var k=window._attKids[i];
      var status=document.getElementById('att-btn-'+k.id).dataset.status;
      await sbPost('attendance',{student_id:k.id,date:date,status:status,marked_by:session.teacherName});
    }
    alert('Attendance saved.');loadFlags('att-flags');
  }catch(e){alert('Could not save attendance: '+e.message);}
}
async function loadFlags(targetId){
  var el=document.getElementById(targetId);
  try{
    var rows=await sbGet('attendance?select=*,students(name,class_arm)&order=date.desc&limit=1000');
    var byStudent={};
    rows.forEach(function(r){if(!byStudent[r.student_id])byStudent[r.student_id]=[];if(byStudent[r.student_id].length<3)byStudent[r.student_id].push(r);});
    var flagged=Object.keys(byStudent).filter(function(sid){var last3=byStudent[sid];var absences=last3.filter(function(r){return r.status==='absent';}).length;return last3.length>=2 && absences>=2;});
    if(!flagged.length){el.innerHTML='<div class="empty-txt">No flagged students right now.</div>';return;}
    el.innerHTML=flagged.map(function(sid){
      var rec=byStudent[sid][0];var name=rec.students?rec.students.name:'Student';var cls=rec.students?rec.students.class_arm:'';
      var absCount=byStudent[sid].filter(function(r){return r.status==='absent';}).length;
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(name)+'</div><div class="lb-sub">'+esc(cls||'')+'</div></div><span class="flag-badge">'+absCount+'/3 absent</span></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load attendance.</div>';}
}
async function loadInsClass(){
  var cls=document.getElementById('ins-class').value.trim();
  var el=document.getElementById('ins-roster');
  if(!cls){alert('Enter a class name first.');return;}
  el.innerHTML='<div class="loading-txt">Loading roster\u2026</div>';
  try{
    var kids=await sbGet('students?class_arm=eq.'+encodeURIComponent(cls)+'&select=*&order=name.asc');
    if(!kids.length){el.innerHTML='<div class="empty-txt">No students found in that class.</div>';return;}
    el.innerHTML=kids.map(function(k){return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(k.name)+'</div></div><input type="number" min="0" max="100" placeholder="Mark" style="width:80px;padding:6px 10px;border:1.5px solid var(--border);border-radius:8px;" id="ins-mark-'+k.id+'" /></div>';}).join('')+'<button class="btn gold" style="margin-top:14px;" onclick="saveInspection()">Save Inspection</button>';
    window._insKids=kids;
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load class.</div>';}
}
async function saveInspection(){
  var date=document.getElementById('ins-date').value;
  if(!date||!window._insKids){alert('Load a class and pick a date first.');return;}
  try{
    for(var i=0;i<window._insKids.length;i++){
      var k=window._insKids[i];
      var mark=document.getElementById('ins-mark-'+k.id).value;
      if(mark==='')continue;
      await sbPost('inspections',{student_id:k.id,date:date,mark:Number(mark),created_by:session.teacherName});
    }
    alert('Inspection marks saved.');
  }catch(e){alert('Could not save: '+e.message);}
}
async function loadProfile(){
  try{
    var t=await sbGet('teachers?id=eq.'+session.teacherId+'&select=*');
    var info=t[0]||{};
    var photoHTML=info.photo_url?'<img src="'+esc(info.photo_url)+'" style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:3px solid var(--gold);margin-bottom:14px;" />':'<div style="width:96px;height:96px;border-radius:50%;background:var(--blue-tint);display:flex;align-items:center;justify-content:center;font-family:\'Playfair Display\',serif;font-size:32px;color:var(--navy);margin-bottom:14px;">'+esc((info.name||'?').charAt(0))+'</div>';
    document.getElementById('profile-info').innerHTML=photoHTML+'<div class="fg"><label>Name</label><div>'+esc(info.name||'')+'</div></div><div class="fg"><label>Subject</label><div>'+esc(info.subject||'\u2014')+'</div></div><div class="fg"><label>Class</label><div>'+esc(info.class_arm||'\u2014')+'</div></div>';
  }catch(e){}
}
// Parents see their children's teachers: name, subject, photo — no phone.
async function loadChildTeachers(kids){
  try{
    var classes=[...new Set(kids.map(function(k){return k.class_arm;}).filter(Boolean))];
    if(!classes.length)return;
    var q='teachers?class_arm=in.('+classes.map(function(cl){return encodeURIComponent(cl);}).join(',')+')&select=name,subject,class_arm,photo_url&order=name.asc';
    var rows=await sbGet(q);
    if(!rows.length)return;
    document.getElementById('child-teachers-list').innerHTML=rows.map(function(t){
      var av=t.photo_url?'<img src="'+esc(t.photo_url)+'" style="width:44px;height:44px;border-radius:50%;object-fit:cover;border:2px solid var(--gold);" />':'<div style="width:44px;height:44px;border-radius:50%;background:var(--blue-tint);display:flex;align-items:center;justify-content:center;font-family:\'Playfair Display\',serif;font-size:18px;color:var(--navy);">'+esc((t.name||'?').charAt(0))+'</div>';
      return '<div class="lb-row">'+av+'<div class="lb-info"><div class="lb-name">'+esc(t.name)+'</div><div class="lb-sub">'+esc(t.subject||'')+' \u00b7 '+esc(t.class_arm||'')+'</div></div></div>';
    }).join('');
    document.getElementById('teachers-card').style.display='block';
  }catch(e){}
}

// ============================================================
// ADMIN
// ============================================================
function initAdmin(){
  renderNoticeBoard('a-notice-board','all',true);
  loadAdminFlags();loadAdminInspections();loadTermState();loadRoster();
  loadAdmissions();loadAdminExamList();loadAdminCalendar();loadAddonRequests();
  loadManageFamilies();loadManageTeachers();loadManageAssistants();
}
function showAdminTab(name,btn){
  document.querySelectorAll('.at-pane').forEach(function(p){p.style.display='none';});
  document.getElementById('at-'+name).style.display='block';
  btn.parentElement.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
}
async function addFamily(){
  var code=document.getElementById('fam-code').value.trim(),name=document.getElementById('fam-name').value.trim(),phone=document.getElementById('fam-phone').value.trim();
  var photoFile=document.getElementById('fam-photo').files[0];
  if(!code){alert('Enter a family code.');return;}
  try{
    var photoUrl=null;
    if(photoFile)photoUrl=await sbUploadPhoto(photoFile,'family-'+code);
    await sbPost('families',{code:code,parent_name:name,phone:phone,photo_url:photoUrl});
    alert('Family added. They can now log in with code: '+code);
    document.getElementById('fam-code').value='';document.getElementById('fam-name').value='';document.getElementById('fam-phone').value='';document.getElementById('fam-photo').value='';
    loadManageFamilies();
  }catch(e){alert('Could not add family (code may already exist): '+e.message);}
}
async function addStudent(){
  var fcode=document.getElementById('stu-fcode').value.trim(),name=document.getElementById('stu-name').value.trim(),level=document.getElementById('stu-level').value,cls=document.getElementById('stu-class').value.trim(),reg=document.getElementById('stu-reg').value.trim();
  if(!fcode||!name){alert('Family code and child name are required.');return;}
  try{
    var fam=await sbGet('families?code=eq.'+encodeURIComponent(fcode)+'&select=id');
    if(!fam.length){alert('No family found with that code. Add the family first.');return;}
    await sbPost('students',{family_id:fam[0].id,name:name,level:level,class_arm:cls,reg_no:reg});
    alert('Child added.');document.getElementById('stu-name').value='';document.getElementById('stu-class').value='';document.getElementById('stu-reg').value='';
  }catch(e){alert('Could not add child: '+e.message);}
}
async function addTeacher(){
  var code=document.getElementById('tch-code').value.trim(),name=document.getElementById('tch-name-add').value.trim(),subject=document.getElementById('tch-subject').value.trim(),cls=document.getElementById('tch-class').value.trim();
  var photoFile=document.getElementById('tch-photo').files[0];
  if(!code||!name){alert('Code and name are required.');return;}
  try{
    var photoUrl=null;
    if(photoFile)photoUrl=await sbUploadPhoto(photoFile,'teacher-'+code);
    await sbPost('teachers',{code:code,name:name,subject:subject,class_arm:cls,photo_url:photoUrl});
    alert('Teacher added. They can log in with code: '+code);
    document.getElementById('tch-code').value='';document.getElementById('tch-name-add').value='';document.getElementById('tch-subject').value='';document.getElementById('tch-class').value='';document.getElementById('tch-photo').value='';
    loadManageTeachers();
  }catch(e){alert('Could not add teacher (code may already exist): '+e.message);}
}
async function loadManageFamilies(){
  var el=document.getElementById('manage-families-list');
  if(!el)return;
  try{
    var rows=await sbGet('families?select=*,students(name)&order=code.asc');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No families added yet.</div>';return;}
    el.innerHTML=rows.map(function(f){
      var kids=(f.students||[]).map(function(s){return s.name;}).join(', ')||'no children on file';
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(f.code)+' \u2014 '+esc(f.parent_name||'')+'</div><div class="lb-sub">'+esc(f.phone||'')+' \u00b7 '+esc(kids)+'</div></div><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteFamily(\''+f.id+'\')">Delete</button></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load families.</div>';}
}
async function deleteFamily(id){
  if(!confirm('Delete this family? This also deletes all of their children on file. This cannot be undone.'))return;
  try{await sbDelete('families','id=eq.'+id);loadManageFamilies();loadRoster();}catch(e){alert('Could not delete: '+e.message);}
}
async function loadManageTeachers(){
  var el=document.getElementById('manage-teachers-list');
  if(!el)return;
  try{
    var rows=await sbGet('teachers?order=name.asc');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No teachers added yet.</div>';return;}
    el.innerHTML=rows.map(function(t){
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(t.name)+' ('+esc(t.code)+')</div><div class="lb-sub">'+esc(t.subject||'')+' \u00b7 '+esc(t.class_arm||'')+'</div></div><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteTeacher(\''+t.id+'\')">Delete</button></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load teachers.</div>';}
}
async function deleteTeacher(id){
  if(!confirm('Delete this teacher? This cannot be undone.'))return;
  try{await sbDelete('teachers','id=eq.'+id);loadManageTeachers();}catch(e){alert('Could not delete: '+e.message);}
}
async function loadManageAssistants(){
  var el=document.getElementById('manage-assistants-list');
  if(!el)return;
  try{
    var rows=await sbGet('assistants?order=name.asc');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No virtual assistants added yet.</div>';return;}
    el.innerHTML=rows.map(function(a){
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(a.name)+' ('+esc(a.code)+')</div></div><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteAssistant(\''+a.id+'\')">Delete</button></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load assistants.</div>';}
}
async function deleteAssistant(id){
  if(!confirm('Delete this Virtual Assistant login?'))return;
  try{await sbDelete('assistants','id=eq.'+id);loadManageAssistants();}catch(e){alert('Could not delete: '+e.message);}
}
async function updateExistingPhoto(){
  var code=document.getElementById('upd-photo-code').value.trim();
  var file=document.getElementById('upd-photo-file').files[0];
  var msg=document.getElementById('upd-photo-msg');
  msg.textContent='';
  if(!code||!file){msg.style.color='var(--red)';msg.textContent='Enter a code and choose a photo first.';return;}
  try{
    var tch=await sbGet('teachers?code=ilike.'+encodeURIComponent(code)+'&select=id,code');
    if(tch.length){
      var url=await sbUploadPhoto(file,'teacher-'+tch[0].code);
      await sbPatch('teachers','id=eq.'+tch[0].id,{photo_url:url});
      msg.style.color='var(--green)';msg.textContent='Teacher photo updated.';
      document.getElementById('upd-photo-code').value='';document.getElementById('upd-photo-file').value='';
      return;
    }
    var fam=await sbGet('families?code=ilike.'+encodeURIComponent(code)+'&select=id,code');
    if(fam.length){
      var url2=await sbUploadPhoto(file,'family-'+fam[0].code);
      await sbPatch('families','id=eq.'+fam[0].id,{photo_url:url2});
      msg.style.color='var(--green)';msg.textContent='Parent photo updated.';
      document.getElementById('upd-photo-code').value='';document.getElementById('upd-photo-file').value='';
      return;
    }
    msg.style.color='var(--red)';msg.textContent='No teacher or family found with that code.';
  }catch(e){msg.style.color='var(--red)';msg.textContent='Could not update photo: '+e.message;}
}
async function postNotice(){
  var title=document.getElementById('not-title').value.trim(),body=document.getElementById('not-body').value.trim(),aud=document.getElementById('not-audience').value;
  if(!title){alert('Enter a title.');return;}
  try{await sbPost('notices',{title:title,body:body,audience:aud,created_by:session.adminName||'Admin'});document.getElementById('not-title').value='';document.getElementById('not-body').value='';renderNoticeBoard('a-notice-board','all',true);}
  catch(e){alert('Could not post notice: '+e.message);}
}
async function addStudentLB(){
  var week=document.getElementById('lbs-week').value.trim(),name=document.getElementById('lbs-name').value.trim(),cls=document.getElementById('lbs-class').value.trim(),score=document.getElementById('lbs-score').value.trim(),note=document.getElementById('lbs-note').value.trim();
  if(!name){alert('Enter a student name.');return;}
  try{await sbPost('leaderboard_students',{week_label:week,student_name:name,class:cls,score:score||null,note:note});alert('Added to leaderboard.');document.getElementById('lbs-name').value='';document.getElementById('lbs-score').value='';document.getElementById('lbs-note').value='';}
  catch(e){alert('Could not add: '+e.message);}
}
async function addTeacherLB(){
  var month=document.getElementById('lbt-month').value.trim(),name=document.getElementById('lbt-name').value.trim(),score=document.getElementById('lbt-score').value.trim();
  if(!name){alert('Enter a teacher name.');return;}
  try{await sbPost('leaderboard_teachers',{month_label:month,teacher_name:name,score:score||null});alert('Added to leaderboard.');document.getElementById('lbt-name').value='';document.getElementById('lbt-score').value='';}
  catch(e){alert('Could not add: '+e.message);}
}
async function addSpellingBee(){
  var week=document.getElementById('sb-week').value.trim(),name=document.getElementById('sb-name').value.trim(),cls=document.getElementById('sb-class').value.trim(),word=document.getElementById('sb-word').value.trim();
  if(!name){alert('Enter the winners name.');return;}
  try{await sbPost('spelling_bee',{week_label:week,winner_name:name,class:cls,word:word});alert('Spelling Bee winner posted.');document.getElementById('sb-name').value='';document.getElementById('sb-word').value='';}
  catch(e){alert('Could not post: '+e.message);}
}
async function loadAdminFlags(){
  var el=document.getElementById('admin-att-flags');
  try{
    var rows=await sbGet('attendance?select=*,students(name,class_arm)&order=date.desc&limit=1000');
    var byStudent={};rows.forEach(function(r){if(!byStudent[r.student_id])byStudent[r.student_id]=[];if(byStudent[r.student_id].length<3)byStudent[r.student_id].push(r);});
    var flagged=Object.keys(byStudent).filter(function(sid){var last3=byStudent[sid];var absences=last3.filter(function(r){return r.status==='absent';}).length;return last3.length>=2 && absences>=2;});
    if(!flagged.length){el.innerHTML='<div class="empty-txt">No flagged students right now.</div>';return;}
    el.innerHTML=flagged.map(function(sid){
      var rec=byStudent[sid][0];var name=rec.students?rec.students.name:'Student';var cls=rec.students?rec.students.class_arm:'';
      var absCount=byStudent[sid].filter(function(r){return r.status==='absent';}).length;
      return '<div class="flag-row"><div class="lb-info"><div class="lb-name">'+esc(name)+'</div><div class="lb-sub">'+esc(cls||'')+'</div></div><span class="flag-badge">'+absCount+'/3 absent</span></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load attendance.</div>';}
}
async function loadAdminInspections(){
  var el=document.getElementById('admin-inspections');
  try{
    var rows=await sbGet('inspections?select=*,students(name,class_arm)&order=date.desc&limit=1000');
    if(!rows.length){el.innerHTML='<div class="empty-txt">No inspection records yet.</div>';return;}
    var latestDate=rows[0].date;
    var todays=rows.filter(function(r){return r.date===latestDate;}).sort(function(a,b){return a.mark-b.mark;});
    el.innerHTML='<div class="lb-week">'+new Date(latestDate).toLocaleDateString('en-GB')+' \u2014 lowest mark first</div>'+todays.map(function(r){
      return '<div class="lb-row"><div class="lb-info"><div class="lb-name">'+esc(r.students?r.students.name:'Student')+'</div><div class="lb-sub">'+esc(r.students?r.students.class_arm:'')+'</div></div><div class="lb-score">'+esc(r.mark)+'</div></div>';
    }).join('');
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load inspections.</div>';}
}
async function loadTermState(){
  try{var s=await sbGet('school_state?id=eq.1&select=*');if(s.length){document.getElementById('term-year').value=s[0].current_year;document.getElementById('term-num').value=s[0].current_term;}}catch(e){}
}
async function saveTermState(){
  var yr=document.getElementById('term-year').value.trim(),t=Number(document.getElementById('term-num').value);
  try{await sbPatch('school_state','id=eq.1',{current_year:yr,current_term:t});document.getElementById('term-msg').textContent='Saved \u2014 parents now see '+yr+', Term '+t+'.';document.getElementById('term-msg').style.color='var(--green)';}
  catch(e){document.getElementById('term-msg').textContent='Could not save.';document.getElementById('term-msg').style.color='var(--red)';}
}

// ============================================================
// STUDENT ROSTER (shared table renderer — used by Admin & Virtual Assistant)
// ============================================================
function renderRosterTable(students,targetId,editable){
  var el=document.getElementById(targetId);
  if(!students.length){el.innerHTML='<div class="empty-txt">No students found.</div>';return;}
  var rows=students.map(function(s){
    var fam=s.families||{};
    var delCell=editable?'<td><button class="btn sm" style="background:var(--red-bg);color:var(--red);" onclick="deleteStudent(\''+s.id+'\')">Delete</button></td>':'';
    return '<tr><td>'+esc(s.name)+'</td><td>'+esc(s.class_arm||s.level||'')+'</td><td>'+esc(fam.parent_name||'\u2014')+'</td><td>'+esc(fam.phone||'\u2014')+'</td><td>'+esc(fam.code||'\u2014')+'</td>'+delCell+'</tr>';
  }).join('');
  el.innerHTML='<table class="simple"><tr><th>Student</th><th>Class</th><th>Parent</th><th>Phone</th><th>Family Code</th>'+(editable?'<th></th>':'')+'</tr>'+rows+'</table>';
}
async function deleteStudent(id){
  if(!confirm('Delete this student? This cannot be undone.'))return;
  try{await sbDelete('students','id=eq.'+id);loadRoster();}catch(e){alert('Could not delete: '+e.message);}
}
async function loadRoster(){
  var filter=document.getElementById('roster-filter').value.trim();
  var el=document.getElementById('admin-roster-table');
  el.innerHTML='<div class="loading-txt">Loading\u2026</div>';
  try{
    var q='students?select=*,families(code,parent_name,phone)&order=class_arm.asc,name.asc';
    if(filter)q+='&class_arm=ilike.*'+encodeURIComponent(filter)+'*';
    var rows=await sbGet(q);
    renderRosterTable(rows,'admin-roster-table',true);
  }catch(e){el.innerHTML='<div class="empty-txt">Could not load roster.</div>';}
}

